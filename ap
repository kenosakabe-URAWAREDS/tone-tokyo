@import "tailwindcss";

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #F8F6F1;
  color: #2D2D2D;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  max-width: 100%;
  display: block;
}

@media (max-width: 768px) {
  .article-image-wide {
    margin-left: -24px !important;
    margin-right: -24px !important;
  }
}
